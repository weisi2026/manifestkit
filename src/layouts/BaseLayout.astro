---
import UserMenu from '../components/UserMenu.astro';
import { createSupabaseServer } from '../lib/supabase-server';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { title, description = 'Free manifestation tools — timer, affirmations, vision board, moon phase calendar', canonical } = Astro.props;

// 服务端读取登录态，传给 UserMenu（会话在 HttpOnly cookie 里，必须服务端取）
const supabase = createSupabaseServer(Astro.cookies, Astro.request.headers);
const { data: { user } } = await supabase.auth.getUser();
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical || Astro.url.href} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />

  <!-- Google Site Verification -->
  <meta name="google-site-verification" content="K1_Xp3wqzO7mf7I50dNTKBhBdEb-01Jz8IJ-6mGtNF4" />
  <!-- Bing Site Verification -->
  <meta name="msvalidate.01" content="B60249D92590B75D8A16760ADBE59C6F" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url.href} />

  <!-- AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6056859786205773" crossorigin="anonymous"></script>

  <style is:global>
    @import "tailwindcss";
    
    :root {
      --color-primary: #7C3AED;
      --color-primary-light: #A78BFA;
      --color-primary-dark: #5B21B6;
      --color-accent: #D4AF37;
      --color-accent-light: #F5D060;
      --color-bg-dark: #0F0A1E;
      --color-bg-card: #1A1333;
      --color-text: #E8E0F0;
      --color-text-muted: #9B8CB8;
    }

    body {
      background-color: var(--color-bg-dark);
      color: var(--color-text);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    a { color: var(--color-primary-light); }
    a:hover { color: var(--color-accent); }
  </style>
</head>
<body class="min-h-screen flex flex-col">
  <!-- Header -->
  <header class="border-b border-purple-900/50 backdrop-blur-sm bg-[#0F0A1E]/80 sticky top-0 z-50">
    <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-xl font-bold">
        <span>🔮</span>
        <span class="bg-gradient-to-r from-purple-400 to-amber-400 bg-clip-text text-transparent">ManifestKit</span>
      </a>
      <div class="hidden md:flex gap-6 text-sm">
        <a href="/manifest-timer" class="hover:text-amber-400 transition-colors">⏳ Timer</a>
        <a href="/affirmation-generator" class="hover:text-amber-400 transition-colors">✨ Affirmations</a>
        <a href="/vision-board" class="hover:text-amber-400 transition-colors">🎯 Vision Board</a>
        <a href="/moon-phase" class="hover:text-amber-400 transition-colors">🌙 Moon Phase</a>
        <a href="/blog" class="hover:text-amber-400 transition-colors">📝 Blog</a>
      </div>
      <div class="flex items-center gap-4">
        <UserMenu user={user} />
        <button id="mobile-menu-btn" class="md:hidden text-2xl">☰</button>
      </div>
    </nav>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden px-4 pb-3 space-y-2 text-sm">
      <a href="/manifest-timer" class="block py-1 hover:text-amber-400">⏳ Manifestation Timer</a>
      <a href="/affirmation-generator" class="block py-1 hover:text-amber-400">✨ Affirmation Generator</a>
      <a href="/vision-board" class="block py-1 hover:text-amber-400">🎯 Vision Board</a>
        <a href="/moon-phase" class="block py-1 hover:text-amber-400">🌙 Moon Phase</a>
        <a href="/blog" class="block py-1 hover:text-amber-400">📝 Blog</a>
     </div>
  </header>

  <!-- Main Content -->
  <main class="flex-1 max-w-6xl mx-auto px-4 py-8 w-full">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-purple-900/50 py-8 text-center text-sm text-[#9B8CB8]">
    <div class="max-w-6xl mx-auto px-4">
      <p>🔮 ManifestKit — Free Spiritual Tools for Conscious Creators</p>
      <p class="mt-2">
        <a href="/about" class="hover:text-amber-400">About</a> ·
        <a href="/blog" class="hover:text-amber-400">Blog</a> ·
        <a href="/affirmation-generator" class="hover:text-amber-400">Affirmations</a> ·
        <a href="/moon-phase" class="hover:text-amber-400">Moon Phases</a>
      </p>
      <p class="mt-2">© 2026 ManifestKit. Made with 💜 and intention.</p>
    </div>
  </footer>

  <!-- Mobile Menu Toggle -->
  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  </script>

  <!-- Schema.org WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "ManifestKit",
    "url": "https://manifestkit.cc.cd",
    "description": "Free manifestation tools — timer, affirmations, vision board, moon phase calendar"
  })} />
</body>
</html>