---
interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: string;
    image?: string;
  };
}

const { frontmatter } = Astro.props;
const { title, description, date, image } = frontmatter;
import BaseLayout from './BaseLayout.astro';
---

<BaseLayout title={`${title} | ManifestKit Blog`} description={description}>
  <article class="bg-[#1A1333] rounded-2xl shadow-lg border border-purple-800/40 p-6 md:p-10">
    <header class="mb-8 border-b border-purple-800/40 pb-6">
      <h1 class="text-3xl md:text-4xl font-bold bg-gradient-to-r from-purple-300 to-amber-300 bg-clip-text text-transparent mb-3">{title}</h1>
      <div class="flex items-center gap-3 text-sm text-[#9B8CB8]">
        <time datetime={date}>{new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        <span>·</span>
        <span>🔮 ManifestKit</span>
      </div>
    </header>
    {image && (
      <div class="mb-8 rounded-xl overflow-hidden">
        <img src={image} alt={title} class="w-full h-auto object-cover" loading="lazy" />
      </div>
    )}
    <div class="prose prose-invert prose-purple max-w-none text-[#E8E0F0] leading-relaxed
      [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:bg-gradient-to-r [&_h2]:from-purple-300 [&_h2]:to-amber-300 [&_h2]:bg-clip-text [&_h2]:text-transparent [&_h2]:mt-10 [&_h2]:mb-4
      [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-amber-300 [&_h3]:mt-8 [&_h3]:mb-3
      [&_p]:text-[#E8E0F0] [&_p]:leading-relaxed [&_p]:mb-4
      [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_ul]:mb-4 [&_ul]:text-[#E8E0F0]
      [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:space-y-2 [&_ol]:mb-4 [&_ol]:text-[#E8E0F0]
      [&_li]:text-[#E8E0F0] [&_li]:leading-relaxed
      [&_blockquote]:border-l-4 [&_blockquote]:border-amber-400/60 [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-amber-200/80 [&_blockquote]:my-6
      [&_strong]:text-amber-300 [&_strong]:font-semibold
      [&_em]:text-purple-300
      [&_a]:text-purple-400 [&_a]:underline [&_a]:hover:text-amber-400
      [&_code]:bg-purple-900/40 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-amber-300 [&_code]:text-sm
      [&_pre]:bg-[#0F0A1E] [&_pre]:rounded-xl [&_pre]:p-4 [&_pre]:overflow-x-auto [&_pre]:my-6
      [&_table]:w-full [&_table]:rounded-lg [&_table]:overflow-hidden [&_table]:mb-6
      [&_th]:bg-purple-900/40 [&_th]:px-4 [&_th]:py-2 [&_th]:text-left [&_th]:text-amber-300 [&_th]:font-semibold
      [&_td]:px-4 [&_td]:py-2 [&_td]:border-t [&_td]:border-purple-800/30
      [&_hr]:border-purple-800/40 [&_hr]:my-8
      [&_img]:rounded-xl [&_img]:my-6
    ">
      <slot />
    </div>
  </article>

  <div class="mt-8 text-center">
    <a href="/blog" class="inline-flex items-center gap-2 text-purple-400 hover:text-amber-400 transition-colors text-lg">
      <span>←</span>
      <span>Back to Blog</span>
    </a>
  </div>
</BaseLayout>